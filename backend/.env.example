# TerraVista — Backend environment (copy to .env and fill in)

# --- Generative AI (chat assistant) --------------------------------------
# Free key at https://openrouter.ai/keys . If left empty, /api/chat falls back
# to a deterministic offline mock (the demo still works without a key).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Cheap paid fallback used only when the free model is rate-limited / errors.
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_TIMEOUT=20
OPENROUTER_MAX_TOKENS=512

# --- Auth (mock, MVP scope) ----------------------------------------------
AUTH_USERNAME=admin
AUTH_PASSWORD=terravista
AUTH_SECRET=change-me-in-production

# --- CORS ----------------------------------------------------------------
# Comma-separated list of allowed origins ("*" allows all — fine for the MVP).
CORS_ORIGINS=*

# --- Supabase (optional) -------------------------------------------------
# Persists IoT sensor readings (Postgres). If left empty, the backend falls
# back to an in-memory ring buffer (the demo still works without Supabase).
# 1) Create a project at https://supabase.com
# 2) Run backend/supabase_schema.sql in the SQL Editor
# 3) Settings → API: copy the Project URL and the service_role key below
# 4) Optionally seed: backend/.venv/bin/python backend/seed_data.py
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_TABLE=sensor_readings

