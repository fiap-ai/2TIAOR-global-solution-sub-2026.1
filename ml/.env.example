# TerraVista ML — environment variables (copy to ml/.env and fill in)
# Only needed for REAL datasets. The synthetic generator needs none of these.

# NASA FIRMS active-fire API key (free): see docs/ACCOUNTS_SETUP.md §3
FIRMS_MAP_KEY=

# Optional FIRMS query tuning (defaults shown).
# Uses the /area/ endpoint with a bounding box (west,south,east,north),
# which works with a standard free MAP_KEY.
FIRMS_SOURCE=VIIRS_SNPP_NRT
FIRMS_AREA=BRA
FIRMS_BBOX=-74,-34,-34,6
FIRMS_DAYS=1


# Kaggle uses ~/.kaggle/kaggle.json (not this file): see docs/ACCOUNTS_SETUP.md §2
